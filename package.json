{
  "name": "intercom-desk",
  "version": "1.0.0",
  "description": "Intercom Desk — Customer Support Agent Console & Web Dashboard. Davexinoh Fork.",
  "main": "index.js",
  "scripts": {
    "start":       "concurrently \"npm run api\" \"npm run cli\"",
    "api":         "node api/server.js",
    "cli":         "node cli/cli.js",
    "web":         "npm --prefix web run dev",
    "dev":         "concurrently \"npm run api\" \"npm run web\" \"npm run cli\"",
    "seed":        "node seed.js",
    "install:web": "npm --prefix web install"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "cors":         "^2.8.5",
    "express":      "^4.18.2"
  },
  "keywords": ["intercom", "trac-network", "support", "helpdesk", "customer-support", "agent-console"],
  "license": "MIT"
}
